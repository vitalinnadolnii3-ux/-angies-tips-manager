{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'manager')",
        ".write": "auth != null && ((!data.exists() && auth.uid === $uid) || root.child('users').child(auth.uid).child('role').val() === 'admin' || (auth.uid === $uid && auth.token.email === 'vitalinnadolnii3@gmail.com' && newData.child('role').val() === 'admin' && newData.child('active').val() === true))",
        ".validate": "newData.val() == null || newData.hasChildren(['email','name','role','active'])",
        "email": {
          ".validate": "newData.isString()"
        },
        "name": {
          ".validate": "newData.isString()"
        },
        "role": {
          ".validate": "newData.isString() && newData.val().matches(/^(admin|manager|responsible|waiter)$/)"
        },
        "active": {
          ".validate": "newData.isBoolean()"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "attendance": {
      "$weekStart": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('role').val() === 'responsible')",
        "$date": {
          ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('role').val() === 'responsible')",
          "$uid": {
            ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('role').val() === 'responsible')",
            ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('role').val() === 'responsible')",
            ".validate": "newData.val() == null || (newData.hasChildren(['uid','employeeName','date','workedHours','updatedAt','updatedBy']) && newData.child('uid').val() === $uid && newData.child('date').val() === $date)",
            "uid": {
              ".validate": "newData.isString() && newData.val() === $uid"
            },
            "employeeName": {
              ".validate": "newData.isString()"
            },
            "date": {
              ".validate": "newData.isString() && newData.val() === $date"
            },
            "entryTime1": {
              ".validate": "!newData.exists() || newData.isString()"
            },
            "exitTime1": {
              ".validate": "!newData.exists() || newData.isString()"
            },
            "entryTime2": {
              ".validate": "!newData.exists() || newData.isString()"
            },
            "exitTime2": {
              ".validate": "!newData.exists() || newData.isString()"
            },
            "isRestDay": {
              ".validate": "!newData.exists() || newData.isBoolean()"
            },
            "workedHours": {
              ".validate": "newData.isNumber() && newData.val() >= 0"
            },
            "notes": {
              ".validate": "!newData.exists() || newData.isString()"
            },
            "updatedAt": {
              ".validate": "newData.isString()"
            },
            "updatedBy": {
              ".validate": "newData.isString()"
            },
            "$other": {
              ".validate": false
            }
          }
        }
      }
    },
    "contractHours": {
      "$uid": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('active').val() === true",
        ".write": "auth != null && root.child('users').child(auth.uid).child('active').val() === true && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'manager' || root.child('users').child(auth.uid).child('role').val() === 'responsible')",
        ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 168"
      }
    }
  }
}
